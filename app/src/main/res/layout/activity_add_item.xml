<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".Activities.AddItem">
    <!-- Top Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageButton
            android:id="@+id/btnback"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_arrow_back_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/on_surface" />
        <TextView
            android:id="@+id/pageTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Add New Item"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnback"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/helpIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:src="@android:drawable/ic_menu_help"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/profileIcon"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/on_surface_variant" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profileIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/user_dp_round"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">
            <TextView
                android:id="@+id/inventoryDetailsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inventory Details"
                android:textColor="@color/primary"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/inventoryDetailsSubHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Enter the precise architectural specifications for your new inventory ledger entry. Ensure all metrics align with regional standards."
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/inventoryDetailsHeader" />

            <!-- Barcode Scanner Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/barcodeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_fororderlists"
                android:padding="24dp"
                app:layout_constraintTop_toBottomOf="@id/inventoryDetailsSubHeader">

                <TextView
                    android:id="@+id/barcodeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCAN OR ENTER BARCODE"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_switch_container"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    app:layout_constraintTop_toBottomOf="@id/barcodeLabel">

                    <EditText
                        android:id="@+id/barcodeFieldtext"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="e.g. 890123456789"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/BarcodeNo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/baseline_barcode_reader_24"
                        app:tint="@color/primary"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Form Fields -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/barcodeSection">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Item Name"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/itmeName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_field_card"
                    android:hint="Premium Steel Beam"
                    android:padding="16dp"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/categoryField"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_field_card"
                    android:paddingHorizontal="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MRP (₹)"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/itemMRP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_field_card"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:padding="16dp"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Initial Stock"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/stockQuantity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_field_card"
                    android:hint="100"
                    android:inputType="number"
                    android:padding="16dp"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discount Rate (%)"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/discountRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_field_card"
                    android:hint="5"
                    android:inputType="numberDecimal"
                    android:padding="16dp"
                    android:textSize="16sp" />

                <!-- Weight & Unit Section -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_switch_container"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/weightUnitHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weight &amp; Unit"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:drawableStartCompat="@drawable/itemsicon"
                        android:drawablePadding="8dp"
                        app:drawableTint="@color/primary" />

                    <TextView
                        android:id="@+id/valueLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="VALUE"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/weightUnitHeader" />

                    <EditText
                        android:id="@+id/itemweight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_field_card"
                        android:gravity="center"
                        android:hint="10.00"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        app:layout_constraintTop_toBottomOf="@id/valueLabel" />
                    <TextView
                        android:id="@+id/measurementTypeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="MEASUREMENT TYPE"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/itemweight" />
                    <LinearLayout
                        android:id="@+id/QuantityTypeContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/measurementTypeLabel">
                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:useDefaultMargins="true">

                            <RadioButton
                                android:id="@+id/Kg"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_columnWeight="1"
                                android:background="@drawable/bg_quantity_selector"
                                android:button="@null"
                                android:checked="true"
                                android:gravity="center"
                                android:text="Kg"
                                android:textColor="@color/selector_quantity_text"
                                android:textStyle="bold" />

                            <RadioButton
                                android:id="@+id/gram"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_columnWeight="1"
                                android:background="@drawable/bg_quantity_selector"
                                android:button="@null"
                                android:gravity="center"
                                android:text="g"
                                android:textColor="@color/selector_quantity_text"
                                android:textStyle="bold" />
                            <RadioButton
                                android:id="@+id/ml"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_columnWeight="1"
                                android:background="@drawable/bg_quantity_selector"
                                android:button="@null"
                                android:gravity="center"
                                android:text="ML"
                                android:textColor="@color/selector_quantity_text"
                                android:textStyle="bold" />
                            <RadioButton
                                android:id="@+id/Litre"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_columnWeight="1"
                                android:background="@drawable/bg_quantity_selector"
                                android:button="@null"
                                android:gravity="center"
                                android:text="L"
                                android:textColor="@color/selector_quantity_text"
                                android:textStyle="bold" />
                        </GridLayout>
                        <RadioButton
                            android:id="@+id/Piece"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_quantity_selector"
                            android:button="@null"
                            android:gravity="center"
                            android:text="Pc"
                            android:textColor="@color/selector_quantity_text"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <!-- Pro Tip Card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_pro_tip"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/proTipLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRO TIP"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ensure the weight unit matches your local tax ledger requirements for automated billing calculation."
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/proTipLabel"
                        />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <!-- Bottom Actions -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Clear Entry"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:backgroundTint="@color/primary"
            android:text="SAVE ITEM"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnClear"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>