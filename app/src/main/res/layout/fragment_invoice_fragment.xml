<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Fragments.invoice_fragment"
    >
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        >

        <LinearLayout
            android:id="@+id/inoviceSearchlayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"

            >
            <include
                android:id="@+id/invoiceSearchbar"
                layout="@layout/top_bar_home_page_v1" />
        </LinearLayout>


        <androidx.cardview.widget.CardView
            android:id="@+id/incomeCardView"
            android:layout_width="match_parent"
            android:layout_height="184dp"
           android:layout_margin="20dp"
            app:cardCornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/inoviceSearchlayout"
            >

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_120digree"
                >

                <TextView
                    android:id="@+id/incomeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="40dp"
                    android:fontFamily="@font/poppins_extrabold"
                    android:text="Today's Income"
                    android:textColor="#CCD8FF"
                    android:textSize="14.dp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />

                <TextView
                    android:id="@+id/incomeAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="$600000"
                    android:textColor="@color/white"
                    android:textSize="48dp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="@id/incomeTitle"
                    app:layout_constraintTop_toBottomOf="@id/incomeTitle" />
            
                <androidx.cardview.widget.CardView
                    android:layout_width="195.dp"
                    android:layout_height="28.dp"
                    app:cardCornerRadius="99dp"
                    android:backgroundTint="#66CDD9FF"
                    app:layout_constraintStart_toStartOf="@id/incomeAmount"
                    app:layout_constraintTop_toBottomOf="@id/incomeAmount"
                    >
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        >
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="12dp"
                            android:src="@drawable/streamline_graph_arrow_increase_solid"
                            app:tint="#6FFBBE"
                            />
                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="20dp"
                            android:text="+42.2%"
                            android:textSize="14dp"
                            android:textColor="#6FFBBE"
                            
                            />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="vs yesterday"
                            android:textColor="#CDD9FF"
                            android:gravity="center_vertical"
                            />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>
                
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

        <GridLayout
            android:id="@+id/quickInfoCardsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/incomeCardView">

           <androidx.cardview.widget.CardView
               android:layout_width="163dp"
               android:layout_height="150dp"
               app:cardCornerRadius="12dp"
               android:layout_margin="1dp"
               app:cardElevation="0dp"
               android:backgroundTint="#E6ECF6"

               >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="start"
                    android:paddingTop="20dp"
                    android:paddingRight="24dp"
                    android:paddingLeft="24dp"
                    android:paddingBottom="22dp"
                    >
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_closebucket"
                        android:padding="8dp"
                        android:background="@drawable/bg_icon_gridview_card"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/inventory"
                        android:textAllCaps="true"
                        android:layout_marginTop="20dp"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal"
                        android:gravity="start"
                        >
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1234"
                            android:paddingEnd="5dp"
                            android:textColor="@color/black"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_bold"
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="units"
                            android:textSize="14dp"
                            android:fontFamily="@font/manrope_regular"
                            />
                    </LinearLayout>
                </LinearLayout>
           </androidx.cardview.widget.CardView>

           <androidx.cardview.widget.CardView
               android:layout_width="163dp"
               android:layout_height="150dp"
               app:cardCornerRadius="12dp"
               android:layout_marginStart="30dp"
               app:cardElevation="0dp"
               android:backgroundTint="#E6ECF6"
               >
               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="match_parent"
                   android:orientation="vertical"
                   android:gravity="start"
                   android:paddingTop="20dp"
                   android:paddingRight="24dp"
                   android:paddingLeft="24dp"
                   android:paddingBottom="22dp"
                   >
                   <ImageView
                       android:layout_width="36dp"
                       android:layout_height="36dp"
                       android:src="@drawable/ic_time_stamp"
                       android:padding="8dp"
                       android:background="@drawable/bg_icon_gridview_card"
                       />
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Pending"
                       android:textAllCaps="true"
                       android:layout_marginTop="20dp"
                       android:textColor="@color/textPrimary"
                       android:textSize="12sp"
                       android:textStyle="bold"
                       />
                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="4dp"
                       android:orientation="horizontal"
                       android:gravity="start"
                       >
                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="1234"
                           android:paddingEnd="5dp"
                           android:textColor="@color/black"
                           android:textSize="24sp"
                           android:textStyle="bold"
                           android:fontFamily="@font/manrope_bold"
                           />
                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="orders"
                           android:textSize="14dp"
                           android:fontFamily="@font/manrope_regular"
                           />
                   </LinearLayout>
               </LinearLayout>
           </androidx.cardview.widget.CardView>
           <androidx.cardview.widget.CardView
               android:layout_width="163dp"
               android:layout_height="150dp"
               app:cardCornerRadius="12dp"
               android:layout_marginTop="30dp"
               app:cardElevation="0dp"
               android:backgroundTint="#E6ECF6"

               >
               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="match_parent"
                   android:orientation="vertical"
                   android:gravity="start"
                   android:paddingTop="20dp"
                   android:paddingRight="24dp"
                   android:paddingLeft="24dp"
                   android:paddingBottom="22dp"
                   >
                   <ImageView
                       android:layout_width="36dp"
                       android:layout_height="36dp"
                       android:src="@drawable/ic_bill_print"
                       android:padding="8dp"
                       android:background="@drawable/bg_icon_gridview_card"
                       />
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Invoices"
                       android:textAllCaps="true"
                       android:layout_marginTop="20dp"
                       android:textColor="@color/textPrimary"
                       android:textSize="12sp"
                       android:textStyle="bold"
                       />
                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="4dp"
                       android:orientation="horizontal"
                       android:gravity="start"
                       >
                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="1234"
                           android:paddingEnd="5dp"
                           android:textColor="@color/black"
                           android:textSize="24sp"
                           android:textStyle="bold"
                           android:fontFamily="@font/manrope_bold"
                           />
                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="due"
                           android:textSize="14dp"
                           android:fontFamily="@font/manrope_regular"
                           />
                   </LinearLayout>
               </LinearLayout>
           </androidx.cardview.widget.CardView>
           <androidx.cardview.widget.CardView
               android:layout_width="163dp"
               android:layout_height="150dp"
               app:cardCornerRadius="12dp"
               android:layout_margin="1dp"
               app:cardElevation="0dp"
               android:backgroundTint="#E6ECF6"
               android:layout_marginTop="30dp"
               android:layout_marginLeft="30dp"
               >
               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="match_parent"
                   android:orientation="vertical"
                   android:gravity="start"
                   android:paddingTop="20dp"
                   android:paddingRight="24dp"
                   android:paddingLeft="24dp"
                   android:paddingBottom="22dp"
                   >
                   <ImageView
                       android:layout_width="36dp"
                       android:layout_height="36dp"
                       android:src="@drawable/ic_waller_one"
                       android:padding="8dp"
                       android:background="@drawable/bg_icon_gridview_card"
                       />
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:text="Credit Limit"
                       android:textAllCaps="true"
                       android:layout_marginTop="20dp"
                       android:textColor="@color/textPrimary"
                       android:textSize="12sp"
                       android:textStyle="bold"
                       />
                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="4dp"
                       android:orientation="horizontal"
                       android:gravity="start"
                       >
                       <TextView
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="$123400"
                           android:paddingEnd="5dp"
                           android:textColor="@color/black"
                           android:textSize="24sp"
                           android:textStyle="bold"
                           android:fontFamily="@font/manrope_bold"
                           />
                   </LinearLayout>
               </LinearLayout>
           </androidx.cardview.widget.CardView>


        </GridLayout>

        <LinearLayout
            android:id="@+id/Orders_listTAG"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/quickInfoCardsGrid"
            >

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recents_transaction"
                    android:textColor="@color/textPrimary"
                    android:textSize="20sp"
                    android:fontFamily="@font/manrope_bold"
                    />


            </LinearLayout>
            <TextView
                android:id="@+id/fragment_seeAllTag"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="See All"
                android:textColor="@color/primary"
                android:gravity="center|end"
                android:layout_marginEnd="20dp"
                android:textSize="14sp"
                android:fontFamily="@font/inter_semibold"
                />
        </LinearLayout>
            <ListView
                android:id="@+id/ordersListsview"
                android:layout_width="match_parent"
                android:layout_height="330dp"
                tools:listitem="@layout/orders_list_layout"
                android:layout_marginTop="10dp"
                android:divider="@android:color/transparent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/Orders_listTAG"
                />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.core.widget.NestedScrollView>