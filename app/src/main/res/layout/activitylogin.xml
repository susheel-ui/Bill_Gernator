<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="24dp">

    <!-- Header Logo Container -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="100dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >

        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardBackgroundColor="#0056D2"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_wallet"
                app:tint="@android:color/white" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/manrope_bold"
            android:text="Welcome Back"
            android:textColor="#0F172A"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="342dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/manrope_regular"
            android:gravity="center"
            android:text="Manage your ledger with architectural precision"
            android:textColor="#64748B"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Login Form Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/formCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:strokeColor="#F1F5F9"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Email Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semibold"
                android:text="Email Address"
                android:textColor="#475569"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#F8FAFC"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeColor="#E2E8F0"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_mail"
                app:startIconTint="#94A3B8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="name@company.com"
                    android:inputType="textEmailAddress"
                    android:padding="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Field -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:fontFamily="@font/inter_semibold"
                    android:text="Password"
                    android:textColor="#475569"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/manrope_bold"
                    android:text="Forgot Password?"
                    android:textColor="#0056D2"
                    android:textSize="14sp" />
            </RelativeLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#F8FAFC"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeColor="#E2E8F0"
                app:endIconMode="password_toggle"
                app:endIconTint="#94A3B8"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="#94A3B8">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:padding="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Login Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/manrope_bold"
                android:text="Login"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#0056D2"
                app:cornerRadius="32dp"
                app:elevation="4dp" />

            <!-- Social Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E2E8F0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:fontFamily="@font/inter"
                    android:text="Or continue with"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E2E8F0" />
            </LinearLayout>

            <!--            &lt;!&ndash; Social Buttons &ndash;&gt;-->
            <!--            <LinearLayout-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:layout_marginTop="24dp"-->
            <!--                android:orientation="horizontal">-->

            <!--                <com.google.android.material.button.MaterialButton-->
            <!--                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"-->
            <!--                    android:layout_width="0dp"-->
            <!--                    android:layout_height="56dp"-->
            <!--                    android:layout_marginEnd="8dp"-->
            <!--                    android:layout_weight="1"-->
            <!--                    android:fontFamily="@font/manrope_bold"-->
            <!--                    android:text="Google"-->
            <!--                    android:textAllCaps="false"-->
            <!--                    android:textColor="#1E293B"-->
            <!--                    app:cornerRadius="16dp"-->
            <!--                    app:icon="@drawable/ic_google"-->
            <!--                    app:iconGravity="textStart"-->
            <!--                    app:iconTint="@null"-->
            <!--                    app:strokeColor="#F1F5F9" />-->

            <!--                <com.google.android.material.button.MaterialButton-->
            <!--                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"-->
            <!--                    android:layout_width="0dp"-->
            <!--                    android:layout_height="56dp"-->
            <!--                    android:layout_marginStart="8dp"-->
            <!--                    android:layout_weight="1"-->
            <!--                    android:fontFamily="@font/manrope_bold"-->
            <!--                    android:text="Facebook"-->
            <!--                    android:textAllCaps="false"-->
            <!--                    android:textColor="#1E293B"-->
            <!--                    app:cornerRadius="16dp"-->
            <!--                    app:icon="@drawable/ic_facebook"-->
            <!--                    app:iconGravity="textStart"-->
            <!--                    app:iconTint="#1877F2"-->
            <!--                    app:strokeColor="#F1F5F9" />-->
            <!--            </LinearLayout>-->

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Footer link -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/formCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:text="New to Ledger? "
            android:textColor="#64748B" />

        <TextView
            android:id="@+id/createanaccountbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text="Create an account"
            android:textColor="#0056D2" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>